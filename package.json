{
  "name": "win11-compatibility-scanner",
  "version": "1.0.0",
  "description": "Windows 11 Compatibility Scanner for Windows 10",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.win11scanner.app",
    "productName": "Win11 Compatibility Scanner",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "archiver": "^6.0.0",
    "adm-zip": "^0.5.10"
  }
}
